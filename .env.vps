# VPS profile (production-oriented)
COMPOSE_PROFILES=scrapy,nutch,storm,yacy

# Feature toggles
ENABLE_SCRAPY=true
ENABLE_NUTCH=true
ENABLE_STORMCRAWLER=true
ENABLE_YACY=true
DISTRIBUTED_CRAWLING=true

# Elasticsearch heap (higher for VPS)
ES_JAVA_OPTS=-Xms1536m -Xmx1536m

LOG_LEVEL=INFO
LOG_FILE=logs/search-api.log
API_DOCS_ENABLED=false
SECURITY_RATE_LIMIT=240
SECURITY_RATE_WINDOW_S=60
SECURITY_LOCKDOWN_S=180
