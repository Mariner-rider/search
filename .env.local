# Local development profile (low resource)
COMPOSE_PROFILES=scrapy

# Feature toggles
ENABLE_SCRAPY=true
ENABLE_NUTCH=false
ENABLE_STORMCRAWLER=false
ENABLE_YACY=false
DISTRIBUTED_CRAWLING=false

# Elasticsearch heap (requested 512MB)
ES_JAVA_OPTS=-Xms512m -Xmx512m

LOG_LEVEL=INFO
LOG_FILE=logs/search-api.log
API_DOCS_ENABLED=false
SECURITY_RATE_LIMIT=120
SECURITY_RATE_WINDOW_S=60
SECURITY_LOCKDOWN_S=180
